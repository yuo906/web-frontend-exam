{
  "extends": ["react-app", "react-app/jest", "google", "prettier"],
  "plugins": [],
  "env": {
    "browser": true,
    "es2021": true
  },
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "module"
  },
  "rules": {
    "require-jsdoc": "off",
    "valid-jsdoc": "off",
    "react/react-in-jsx-scope": "off",
    "react/prop-types": "off",
    "new-cap": "off",
    "max-len": [
      "warn",
      {
        "code": 100,
        "ignoreUrls": true,
        "ignoreStrings": true,
        "ignoreTemplateLiterals": true
      }
    ],
    "object-curly-spacing": ["error", "always"]
  },
  "settings": {
    "react": {
      "version": "detect"
    }
  }
}
